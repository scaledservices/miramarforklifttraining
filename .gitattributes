# Git LFS tracking for large binary assets
server/assets/*.pdf filter=lfs diff=lfs merge=lfs -text
server/assets/*.png filter=lfs diff=lfs merge=lfs -text
server/assets/*.jpg filter=lfs diff=lfs merge=lfs -text
server/assets/*.jpeg filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
*.tar.gz filter=lfs diff=lfs merge=lfs -text

# Client public images (stock photos, logos over threshold)
client/public/images/*.jpg filter=lfs diff=lfs merge=lfs -text
client/public/images/*.png filter=lfs diff=lfs merge=lfs -text
client/public/images/*.svg filter=lfs diff=lfs merge=lfs -text

# Ensure consistent line endings
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.sql text eol=lf
